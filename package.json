{
  "name": "hadal",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "HADAL Threat Intelligence Terminal",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.app.json && node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.node.json && vite build",
    "lint": "node ./node_modules/eslint/bin/eslint.js src vite.config.ts eslint.config.js",
    "preview": "vite preview",
    "fetch": "python scripts/fetch_rss.py"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.10",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.3.0"
  }
}
